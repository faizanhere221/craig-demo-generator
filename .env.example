# ═══════════════════════════════════════════════════════════════════
#  Optimo Demo Site Generator — Environment Variables
#
#  Copy this file to .env.local for local development:
#    cp .env.example .env.local
#
#  For production, add each variable in Vercel:
#    vercel env add VARIABLE_NAME production
#  or via: https://vercel.com/[your-team]/demo-site-generator/settings/environment-variables
#
#  Legend:
#    [REQUIRED]  — app will not work without this
#    [optional]  — feature is silently skipped when absent
# ═══════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────
# VERCEL DEPLOYMENT
# ───────────────────────────────────────────────────────────────────

# [REQUIRED] Vercel personal access token — used to deploy each demo
# site as a standalone static project via the Vercel API.
# Create one at: https://vercel.com/account/tokens
# Scope: Full Account (needs deployment write access)
VERCEL_TOKEN=your_vercel_token_here


# ───────────────────────────────────────────────────────────────────
# ANTHROPIC / CLAUDE API
# ───────────────────────────────────────────────────────────────────

# [optional] Claude API key for generating personalised site copy
# (tagline, about text) for each demo. Without this, default copy is used.
# Cost: ~$0.01 per site generated.
# Get it at: https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ───────────────────────────────────────────────────────────────────
# GOHIGHLEVEL (GHL) — CORE
# ───────────────────────────────────────────────────────────────────

# [REQUIRED for GHL features] GHL private integration API key.
# Where to find it:
#   GHL dashboard → Settings → Integrations → API Keys → Create Key
#   Select: Private Integration Key, grant Contacts + Conversations scopes.
GHL_API_KEY=your_ghl_api_key_here

# [REQUIRED for GHL features] Your GHL sub-account (location) ID.
# Where to find it:
#   GHL dashboard → Settings → Business Profile → scroll to "Location ID"
#   It looks like: ve9EPM428h8vShlRW1KT
GHL_LOCATION_ID=your_location_id_here

# [REQUIRED for webhook security] Secret token that GHL includes in every
# outbound webhook request as the header: x-webhook-secret
# Choose any strong random string (e.g. openssl rand -hex 32).
# Add the same value in GHL:
#   GHL → Automations → Webhook action → Add Header
#     Header name:  x-webhook-secret
#     Header value: <this value>
GHL_WEBHOOK_SECRET=your_webhook_secret_here


# ───────────────────────────────────────────────────────────────────
# GOHIGHLEVEL — CUSTOM FIELDS
# Stores the demo URL and creation timestamp back on the GHL contact.
# ───────────────────────────────────────────────────────────────────

# [optional] UUID of the GHL custom field that stores the generated demo URL.
# Falls back to the field key name "demo_site_url" when not set.
# Where to find the UUID:
#   GHL → Settings → Custom Fields → click the field → copy the Field ID
#   It looks like: 6dvNaf7VguHt2K1234ab
GHL_DEMO_URL_FIELD_ID=your_demo_url_field_id_here

# [optional] UUID of the GHL custom field that stores the demo creation timestamp.
# Falls back to the field key name "demo_created_at" when not set.
# Create in GHL → Settings → Custom Fields → Add Field → type: Date
GHL_DEMO_CREATED_AT_FIELD_ID=your_demo_created_at_field_id_here

# [optional] Base URL for GHL contact deep-links shown in the admin dashboard.
# Only needed if you use a white-label domain for GHL (e.g. https://crm.youragency.com).
# Leave unset to use the default: https://app.gohighlevel.com
# GHL_APP_BASE_URL=https://app.gohighlevel.com


# ───────────────────────────────────────────────────────────────────
# GOHIGHLEVEL — FEATURE FLAGS
# ───────────────────────────────────────────────────────────────────

# [optional] Set to "true" to automatically send an SMS to the lead
# via GHL Conversations after their demo site is generated.
# Requires GHL_API_KEY and GHL_LOCATION_ID to be set.
# The SMS is sent using lib/ghl-api.js → sendSMS()
ENABLE_AUTO_SMS=false


# ───────────────────────────────────────────────────────────────────
# GOOGLE SHEETS — PERMANENT STORAGE
# Logs every generated site so links survive Vercel redeployments.
# ───────────────────────────────────────────────────────────────────

# [optional] Google Apps Script web app URL that receives a POST for
# each generated site and appends a row to your spreadsheet.
# Setup steps (one-time):
#   1. Open a Google Sheet
#   2. Extensions → Apps Script → paste the script from lib/google-sheets.js
#   3. Deploy → New deployment → Type: Web app → Anyone can access
#   4. Copy the Web app URL and paste it here
GOOGLE_SHEET_WEBHOOK=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec


# ───────────────────────────────────────────────────────────────────
# NOTIFICATIONS — EMAIL
# Sends an email summary when a new demo site is created.
# ───────────────────────────────────────────────────────────────────

# [optional] Webhook URL of your email provider that accepts a JSON POST
# with fields: { to, from, subject, html }
# Supported providers (configure their webhook/API endpoint here):
#   Resend:    https://api.resend.com/emails
#   SendGrid:  https://api.sendgrid.com/v3/mail/send  (needs auth header — adapt lib/notifications.js)
#   Mailgun:   https://api.mailgun.net/v3/YOUR_DOMAIN/messages
NOTIFY_EMAIL_WEBHOOK=https://api.resend.com/emails

# [optional] Email address that receives the new-demo notification.
# e.g. your own inbox or a team alias.
NOTIFY_EMAIL_TO=craig@optimo.com

# [optional] Sender address shown in the notification email.
# Must be a verified sender in your email provider.
# Defaults to: demos@optimo.agency
NOTIFY_EMAIL_FROM=demos@optimo.agency


# ───────────────────────────────────────────────────────────────────
# NOTIFICATIONS — SLACK
# Posts a formatted message to a Slack channel on each new demo.
# ───────────────────────────────────────────────────────────────────

# [optional] Slack Incoming Webhook URL.
# Create one at: https://api.slack.com/apps → your app → Incoming Webhooks → Add New Webhook
# It looks like: https://hooks.slack.com/services/T00000/B00000/XXXX
NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK


# ───────────────────────────────────────────────────────────────────
# NOTIFICATIONS — DISCORD
# Posts an embed to a Discord channel on each new demo.
# ───────────────────────────────────────────────────────────────────

# [optional] Discord channel webhook URL.
# Create one at: Discord server → channel settings → Integrations → Webhooks → New Webhook
# It looks like: https://discord.com/api/webhooks/123456/TOKEN
NOTIFY_DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK
